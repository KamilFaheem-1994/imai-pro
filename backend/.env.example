# Server Configuration
PORT=4000
NODE_ENV=development

# Database (Neon Postgres)
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# CORS
CORS_ORIGIN=http://localhost:3000

# IMAI API Key (alternative to storing in settings DB table)
IMAI_API_KEY=your_imai_api_key

# OpenRouter (for AI-powered agent screenshot analysis)
OPENROUTER_API_KEY=your_openrouter_key
